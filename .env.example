# ── Backend de GAIA — variables de entorno ──────────────
# Copia este ficheiro a .env e completa os valores reais.
# .env NUNCA se sobe a git (está no .gitignore).

# ── Servidor ──
PORT=4000
# Orixe permitida por CORS. En produción: o dominio real do frontend.
FRONTEND_URL=http://localhost:3000

# ── Autenticación ──
# OBRIGATORIO: cadea longa e aleatoria. Sen ela o servidor non arranca.
JWT_SECRET=
# Opcional (por defecto 7d)
JWT_EXPIRES_IN=7d

# ── Códigos de acceso por rol ──
CODIGO_PROFESOR=
CODIGO_ARQUITECTO=

# ── Neo4j ──
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
# Contrasinal real do teu Neo4j (NON deixar o valor por defecto 'gaia1234').
NEO4J_PASS=

# ── IA (asistente Lúa) ──
# SEGREDO. Clave de Anthropic. Nunca commitear.
ANTHROPIC_API_KEY=sk-ant-...
